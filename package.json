{
  "name": "banmenh-v2",
  "private": true,
  "version": "0.0.0",
  "description": "Ban Menh V2 independent rebuild",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "typecheck": "npm --workspace apps/web run typecheck",
    "lint": "npm --workspace apps/web run lint",
    "kb:validate": "node tools/kb-import/validate-numerology-kb.mjs",
    "kb:test-engine": "node tools/kb-import/test-engine.mjs",
    "kb:test-charts": "node tools/kb-import/test-charts.mjs",
    "kb:test-synthesizer": "node tools/kb-import/test-synthesizer.mjs",
    "kb:test-diacritics": "node tools/kb-import/test-diacritics.mjs",
    "kb:extract-narrative": "node tools/kb-import/extract-narrative.mjs",
    "kb:validate-narrative": "node tools/kb-import/validate-narrative.mjs",
    "kb:upload-kv": "node tools/kb-import/upload-to-kv.mjs",
    "security:smoke": "node tools/security-smoke.mjs",
    "qa:responsive-audit": "node tools/responsive-qa-audit.mjs",
    "check": "npm run typecheck && npm run lint && npm run kb:test-diacritics && npm run security:smoke && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
