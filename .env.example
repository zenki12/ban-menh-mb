# Bản Mệnh V2 environment template.
# File này chỉ là template, không chứa secret thật.
# Secret thật lưu trong 1Password/Bitwarden hoặc file local `.env.local` không commit.
# Cách copy local: cp .env.example .env.local

# App
NEXT_PUBLIC_APP_ENV=your_value_here
NEXT_PUBLIC_APP_NAME=your_value_here
NEXT_PUBLIC_APP_URL=your_value_here
ADMIN_TOKEN=your_value_here

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_value_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_value_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_value_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_value_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_value_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_value_here
GOOGLE_CLIENT_ID=your_value_here
GOOGLE_CLIENT_SECRET=your_value_here
FIREBASE_PROJECT_ID=your_value_here
FIREBASE_CLIENT_EMAIL=your_value_here
FIREBASE_PRIVATE_KEY=your_value_here

# PayOS
PAYOS_CLIENT_ID=your_value_here
PAYOS_API_KEY=your_value_here
PAYOS_CHECKSUM_KEY=your_value_here
PAYOS_WEBHOOK_URL=your_value_here

# Telegram
TELEGRAM_BOT_TOKEN=your_value_here
TELEGRAM_CHAT_ID=your_value_here

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_value_here
CLOUDFLARE_API_TOKEN=your_value_here
CLOUDFLARE_PAGES_PROJECT_DEV=your_value_here
CLOUDFLARE_PAGES_PROJECT_PROD=your_value_here
CLOUDFLARE_R2_BUCKET=your_value_here
CLOUDFLARE_KV_NAMESPACE_ID=your_value_here
PAYMENT_WORKER_NAME=your_value_here
KB_WORKER_NAME=your_value_here
ADMIN_WORKER_NAME=your_value_here
KB_STORAGE_BUCKET=your_value_here
